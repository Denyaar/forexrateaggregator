# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/forexratedb
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Redis Configuration (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Security Configuration
# Generate a strong secret key (min 256 bits / 32 characters)
JWT_SECRET=your_jwt_secret_key_min_32_characters_long

# External Forex API Keys
# ExchangeRate-API (free tier available)
EXCHANGERATE_API_KEY=your_exchangerate_api_key

# Fixer API (requires paid subscription)
FIXER_API_KEY=your_fixer_api_key

# CurrencyLayer API (requires paid subscription)
CURRENCYLAYER_API_KEY=your_currencylayer_api_key