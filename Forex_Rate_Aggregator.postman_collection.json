{
	"info": {
		"_postman_id": "forex-rate-aggregator-001",
		"name": "Forex Rate Aggregator API",
		"description": "Complete API collection for Forex Rate Aggregator service with authentication, rate fetching, and admin operations",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8989",
			"type": "string"
		},
